generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
  CHANGE_PHONE
}

enum UserRole {
  CUSTOMER
  ADMIN
  CASHIER
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum SpinPrizeType {
  points
  multiplier
}

model Otp {
  id String @id @default(uuid())

  phone   String
  userId  String?
  user    User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code    String
  purpose OtpPurpose
  status  OtpStatus  @default(PENDING)

  attempts       Int       @default(0)
  rateLimitLevel Int       @default(1)
  blockedUntil   DateTime?
  requestCount   Int       @default(1)
  ipAddress      String?

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id String @id @default(uuid())

  role        UserRole @default(CUSTOMER)
  userName    String?
  firstName   String
  lastName    String
  phone       String   @unique
  dateOfBirth DateTime
  password    String

  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pointsTransactions PointsTransaction[]
  Otps               Otp[]
  spinWheelSpins     SpinWheelSpin[]
  storeCashier       StoreCashier?
}

model Store {
  id           String       @id @default(uuid())
  name         String
  address      String
  phone        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  workingHours Json?
  location     Json?
  images       StoreImage[]

  cashiers           StoreCashier[]
  pointsTransactions PointsTransaction[]

  @@map("stores")
}

// One-to-one: a cashier is assigned to exactly one store, but a store can
// have many cashiers. Deleting either side just removes the assignment row.
model StoreCashier {
  id        String @id @default(cuid())
  cashierId String @unique @map("cashier_id")
  storeId   String @map("store_id")

  cashier User  @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("store_cashiers")
}

model StoreImage {
  id        String   @id @default(uuid())
  storeId   String
  url       String
  path      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Advertisement {
  id String @id @default(uuid())

  name        String
  description String
  images      AdvertisementImage[]
  startDate   DateTime
  endDate     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdvertisementImage {
  id              String  @id @default(uuid())
  advertisementId String
  url             String
  path            String
  size            Int?
  mimeType        String?

  createdAt DateTime @default(now())

  advertisement Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
}

// Menu — uses Int auto-increment ids intentionally (frontend already built
// against integer ids for these pages), unlike the rest of this schema.
model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      String
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String
  updatedBy String
  items     MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          Int             @id @default(autoincrement())
  categoryId  Int
  category    MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String
  updatedBy   String
  images      MenuItemImage[]

  rewards PointsReward[]

  @@map("menu_items")
}

model MenuItemImage {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  path      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@map("menu_item_images")
}

model PointsLevel {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(50)
  minPeriodPoints Decimal  @map("min_period_points") @db.Decimal(10, 2)
  earnRate        Decimal  @map("earn_rate") @db.Decimal(10, 4)
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String   @map("created_by") @db.VarChar(100) // JWT userId
  updatedBy       String   @map("updated_by") @db.VarChar(100) // JWT userId

  // Relations
  userStates PointsUserState[]

  @@map("points_levels")
}

model PointsSetting {
  id                   Int      @id @default(1)
  evaluationPeriodDays Int      @map("evaluation_period_days")
  signupBonusPoints    Decimal  @map("signup_bonus_points") @db.Decimal(10, 2)
  birthdayBonusPoints  Decimal  @map("birthday_bonus_points") @db.Decimal(10, 2)
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String   @map("updated_by") @db.VarChar(100)

  @@map("points_settings")
}

model PointsReward {
  id             String   @id @default(uuid()) @db.Uuid
  menuItemId     Int      @map("menu_item_id")
  pointsRequired Decimal  @map("points_required") @db.Decimal(10, 2) // Points required
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  redeemItems PointsRedeemItem[]

  // Relations
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@map("points_rewards")
}

enum TransactionType {
  signup_bonus
  purchase_earn
  spin_reward
  spin_multiplier
  birthday_bonus
  redeem
  admin_adjustment
}

enum TransactionReferenceType {
  SIGNUP
  PURCHASE
  SPIN
  REWARD
  BIRTHDAY
  SYSTEM
}

model PointsTransaction {
  id     String          @id @default(uuid()) @db.Uuid
  userId String          @map("user_id")
  type   TransactionType

  referenceType TransactionReferenceType? @map("reference_type")
  referenceId   String?                   @map("reference_id")
  reason        String?                   @db.VarChar(255)

  points       Decimal            @db.Decimal(10, 2)
  balanceAfter Decimal            @map("balance_after") @db.Decimal(10, 2)
  createdAt    DateTime           @default(now()) @map("created_at")
  createdBy    String             @map("created_by") @db.VarChar(100)
  redeemItems  PointsRedeemItem[]

  // Snapshot of the acting cashier's branch at write time — frozen on
  // creation so it survives the Store or the cashier's User row being
  // deleted or renamed later. storeId stays a live FK for joins/filters
  // while the store still exists.
  storeId     String? @map("store_id")
  storeName   String? @map("store_name") @db.VarChar(150)
  cashierName String? @map("cashier_name") @db.VarChar(150)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
  @@index([storeId])
  @@map("points_transactions")
}

model PointsUserState {
  userId             String   @id @map("user_id") @db.Uuid
  currentBalance     Decimal  @map("current_balance") @db.Decimal(10, 2)
  currentLevelId     String?  @map("current_level_id") @db.Uuid
  periodPointsEarned Decimal  @map("period_points_earned") @db.Decimal(10, 2)
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  currentLevel PointsLevel? @relation(fields: [currentLevelId], references: [id], onDelete: SetNull)

  @@map("points_user_state")
}

model PointsRedeemItem {
  id String @id @default(uuid()) @db.Uuid

  transactionId String @map("transaction_id") @db.Uuid

  rewardId String @map("reward_id") @db.Uuid

  quantity Int

  pointsPerItem Decimal @map("points_per_item") @db.Decimal(10, 2)

  totalPoints Decimal @map("total_points") @db.Decimal(10, 2)

  transaction PointsTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  reward PointsReward @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  @@map("points_redeem_items")
}

model SpinWheelPrize {
  id                 String          @id @default(uuid())
  label              String          @db.VarChar(50)
  type               SpinPrizeType
  value              Decimal         @db.Decimal(10, 2)
  probabilityPercent Decimal         @db.Decimal(5, 2)
  sortOrder          Int
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String          @db.VarChar(100)
  updatedBy          String          @db.VarChar(100)
  spins              SpinWheelSpin[]

  @@map("spin_wheel_prizes")
}

model SpinWheelSettings {
  id            Int      @id @default(1)
  cooldownHours Int      @default(24)
  updatedAt     DateTime @updatedAt
  updatedBy     String   @db.VarChar(100)

  @@map("spin_wheel_settings")
}

model SpinWheelSpin {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  prizeId     String?
  prize       SpinWheelPrize? @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  rewardType  SpinPrizeType
  rewardValue Decimal         @db.Decimal(10, 2)
  spunAt      DateTime
  createdAt   DateTime        @default(now())

  @@index([userId, spunAt])
  @@map("spin_wheel_spins")
}

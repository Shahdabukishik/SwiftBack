generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
  CHANGE_PHONE
}

enum UserRole {
  CUSTOMER
  ADMIN
  CASHIER
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

model Otp {
  id          String      @id @default(uuid())

  phone       String
   userId      String?
  user         User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String
  purpose     OtpPurpose
  status      OtpStatus   @default(PENDING)

  attempts       Int        @default(0)
  rateLimitLevel Int        @default(1)
  blockedUntil   DateTime?
  requestCount   Int        @default(1)
  ipAddress      String?

  expiresAt   DateTime
  createdAt   DateTime    @default(now())


}

model User {
  id           String    @id @default(uuid())


  role         UserRole @default(CUSTOMER)
  userName     String?  
  firstName    String
  lastName     String
  phone        String    @unique
  dateOfBirth  DateTime
  password     String

  isVerified  Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  pointsTransactions PointsTransaction[]
  Otps Otp[]
}

model Store {
  id           String       @id @default(uuid())
  name         String
  address      String
  phone        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  workingHours Json?
  location     Json?
  images       StoreImage[]

  @@map("stores")
}

model StoreImage {
  id        String   @id @default(uuid())
  storeId   String
  url       String
  path      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Advertisement {
  id           String       @id @default(uuid())

  name         String
  description  String
  images       AdvertisementImage[]
  startDate    DateTime
  endDate      DateTime


  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

}

model AdvertisementImage {
  id        String   @id @default(uuid())
  advertisementId   String
  url       String
  path      String
  size      Int?
  mimeType  String?

  createdAt DateTime @default(now())

  advertisement     Advertisement    @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
}

// Menu — uses Int auto-increment ids intentionally (frontend already built
// against integer ids for these pages), unlike the rest of this schema.
model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      String
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String
  updatedBy String
  items     MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          Int             @id @default(autoincrement())
  categoryId  Int
  category    MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String
  updatedBy   String
  images      MenuItemImage[]
  
  rewards     PointsReward[]
  @@map("menu_items")
}

model MenuItemImage {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  path      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@map("menu_item_images")
}

model PointsLevel {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @db.VarChar(50) 
  minPeriodPoints  Decimal           @map("min_period_points") @db.Decimal(10, 2) 
  earnRate         Decimal           @map("earn_rate") @db.Decimal(10, 4) 
  sortOrder        Int               @map("sort_order") 
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  createdBy        String            @map("created_by") @db.VarChar(100) // JWT userId
  updatedBy        String            @map("updated_by") @db.VarChar(100) // JWT userId
  
  // Relations
  userStates       PointsUserState[]

  @@map("points_levels")
}

model PointsSetting {
  id                   Int      @id @default(1)
  evaluationPeriodDays Int      @map("evaluation_period_days")
  signupBonusPoints    Decimal  @map("signup_bonus_points") @db.Decimal(10, 2)
  birthdayBonusPoints  Decimal  @map("birthday_bonus_points") @db.Decimal(10, 2)
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String   @map("updated_by") @db.VarChar(100)

  @@map("points_settings")
}

model PointsReward {
  id             String   @id @default(uuid()) @db.Uuid
  menuItemId     Int      @map("menu_item_id")
  pointsRequired Decimal  @map("points_required") @db.Decimal(10, 2) // Points required
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@map("points_rewards")
}

enum TransactionType {
  signup_bonus
  purchase_earn
  spin_reward
  spin_multiplier
  birthday_bonus
  redeem
}

model PointsTransaction {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") 
  type         TransactionType
  points       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @map("balance_after") @db.Decimal(10, 2)
  createdAt    DateTime        @default(now()) @map("created_at")
  createdBy    String          @map("created_by") @db.VarChar(100)

 user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("points_transactions")
}

model PointsUserState {
  userId             String       @id @map("user_id") @db.Uuid
  currentBalance     Decimal      @map("current_balance") @db.Decimal(10, 2)
  currentLevelId     String?      @map("current_level_id") @db.Uuid
  periodPointsEarned Decimal      @map("period_points_earned") @db.Decimal(10, 2)
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Relations
  currentLevel       PointsLevel? @relation(fields: [currentLevelId], references: [id], onDelete: SetNull)

  @@map("points_user_state")
}